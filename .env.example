# Required environment variables — set these in Vercel project settings (Settings → Environment Variables)
# Do NOT commit your .env file to git.

# Umami Cloud API key (https://cloud.umami.is)
UMAMI_API_KEY=api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq API key (https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SEO Score API key (https://seoscoreapi.com)
SEO_SCORE_API_KEY=ssa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
